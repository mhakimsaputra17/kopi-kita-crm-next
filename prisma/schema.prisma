generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Better Auth tables ───

model User {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions      Session[]
  accounts      Account[]
  conversations ChatConversation[]

  @@map("users")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("accounts")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt

  @@map("verifications")
}

// ─── App: Customer ───

model Customer {
  id           String   @id @default(cuid())
  name         String
  contact      String?
  favoriteDrink String  @map("favorite_drink")
  interestTags String[] @map("interest_tags")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([name])
  @@index([interestTags], type: Gin)
  @@map("customers")
}

// ─── App: Promo Campaign ───

model PromoCampaign {
  id            String   @id @default(cuid())
  theme         String
  segment       String
  customerCount Int      @map("customer_count")
  whyNow        String   @map("why_now")
  message       String
  timeWindow    String?  @map("time_window")
  createdAt     DateTime @default(now()) @map("created_at")

  batchId String @map("batch_id")
  batch   PromoBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([createdAt(sort: Desc)])
  @@map("promo_campaigns")
}

model PromoBatch {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")

  campaigns PromoCampaign[]

  @@map("promo_batches")
}

// ─── App: Chat History (ChatGPT-like) ───

model ChatConversation {
  id        String   @id @default(cuid())
  title     String   @default("Chat Baru")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages ChatMessage[]

  @@index([userId, updatedAt(sort: Desc)])
  @@map("chat_conversations")
}

model ChatMessage {
  id             String   @id @default(cuid())
  conversationId String   @map("conversation_id")
  role           String   // "user" | "assistant"
  content        String
  createdAt      DateTime @default(now()) @map("created_at")

  conversation ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("chat_messages")
}
