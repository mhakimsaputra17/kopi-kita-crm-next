# ─── Kopi Kita — Environment Variables ───

# Database (Neon Postgres — get from neon.tech dashboard)
DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=verify-full&channel_binding=require"

# Better Auth (generate secret: openssl rand -base64 32)
BETTER_AUTH_SECRET="your-secret-min-32-chars"
BETTER_AUTH_URL="http://localhost:3000"

# AI Provider — GitHub Models
# Get tokens from: https://github.com/settings/tokens (needs models:read permission)
# Multiple tokens = more rate limit capacity (each token has independent quota)
GITHUB_TOKEN="your-github-token-here"
GITHUB_TOKEN_2="your-github-token-2-here"
GITHUB_TOKEN_3="your-github-token-3-here"

# AI Provider — Google Gemini
# Get API key from: https://aistudio.google.com/apikey
GEMINI_API_KEY="your-gemini-api-key-here"

# Upstash Redis (get from console.upstash.com)
UPSTASH_REDIS_REST_URL="https://your-redis.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token-here"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Seed User (used by: bun run db:seed)
SEED_USER_NAME="Mimi"
SEED_USER_EMAIL="mimi@kopikita.com"
SEED_USER_PASSWORD="your-seed-password-here"
